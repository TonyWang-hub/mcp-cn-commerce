# ==========================================
# mcp-cn-commerce — Environment Configuration
# ==========================================
# Copy this file to .env and fill in your credentials
# WARNING: Never commit .env to version control

# ──────────────────────────────────────────
# Phase 1 — Foundation
# ──────────────────────────────────────────

# 巨量引擎 (Ocean Engine) — Advertising Platform
# Get credentials: https://open.oceanengine.com → Developer Console
OCEANENGINE_APP_KEY=your_app_key_here
OCEANENGINE_APP_SECRET=your_app_secret_here
OCEANENGINE_ACCESS_TOKEN=your_access_token_here

# 抖店 (Douyin Shop) — TikTok Shop China
# Get credentials: https://op.jinritemai.com → Developer Console
DOUDIAN_APP_KEY=your_app_key_here
DOUDIAN_APP_SECRET=your_app_secret_here
DOUDIAN_SHOP_ID=your_shop_id_here
DOUDIAN_ACCESS_TOKEN=your_access_token_here

# 京东 (JD.com) — Jingdong E-Commerce
# Get credentials: https://jos.jd.com → Developer Console
JD_APP_KEY=your_app_key_here
JD_APP_SECRET=your_app_secret_here
JD_ACCESS_TOKEN=your_access_token_here

# ──────────────────────────────────────────
# Phase 2 — Mid-Tier Expansion
# ──────────────────────────────────────────

# 淘宝 (Taobao) — Alibaba E-Commerce
# Get credentials: https://open.taobao.com → Developer Console
TAOBAO_APP_KEY=your_app_key_here
TAOBAO_APP_SECRET=your_app_secret_here
TAOBAO_ACCESS_TOKEN=your_access_token_here

# 拼多多 (Pinduoduo) — PDD E-Commerce
# Get credentials: https://open.pinduoduo.com → Developer Console
PINDUODUO_CLIENT_ID=your_client_id_here
PINDUODUO_CLIENT_SECRET=your_client_secret_here
PINDUODUO_ACCESS_TOKEN=your_access_token_here

# ──────────────────────────────────────────
# Phase 3 — Long-Tail Coverage
# ──────────────────────────────────────────

# 快手 (Kuaishou) — Kuaishou E-Commerce
# Get credentials: https://open.kuaixiaodian.com → Developer Console
KUAISHOU_APP_KEY=your_app_key_here
KUAISHOU_APP_SECRET=your_app_secret_here
KUAISHOU_SIGN_SECRET=your_sign_secret_here
KUAISHOU_ACCESS_TOKEN=your_access_token_here

# 小红书 (Xiaohongshu) — XHS E-Commerce
# Get credentials: https://open.xiaohongshu.com → Developer Console
XHS_CLIENT_ID=your_client_id_here
XHS_CLIENT_SECRET=your_client_secret_here
XHS_ACCESS_TOKEN=your_access_token_here

# 微信小店 (WeChat Store) — WeChat E-Commerce
# Get credentials: https://developers.weixin.qq.com → Developer Console
WEIXIN_APP_ID=your_app_id_here
WEIXIN_APP_SECRET=your_app_secret_here
WEIXIN_ACCESS_TOKEN=your_access_token_here
